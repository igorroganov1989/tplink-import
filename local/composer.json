{
    "name": "yd/tplink-test",
    "description": "TP-Link catalog import for 1C-Bitrix",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "andreyryabin/sprint.migration": "^5.0",
        "wikimedia/composer-merge-plugin": "^2.0"
    },
    "extra": {
        "installer-paths": {
            "modules/{$name}/": ["type:bitrix-module"]
        },
        "merge-plugin": {
            "include": [
                "../bitrix/composer-bx.json"
            ],
            "recurse": true,
            "replace": false,
            "ignore-duplicates": false,
            "merge-dev": true,
            "merge-extra": true,
            "merge-extra-deep": true,
            "merge-replace": true,
            "merge-scripts": false
        }
    },
    "autoload": {
        "psr-4": {
            "Yd\\TplinkImport\\": "modules/yd.tplink.import/lib/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/installers": true,
            "wikimedia/composer-merge-plugin": true
        }
    }
}
